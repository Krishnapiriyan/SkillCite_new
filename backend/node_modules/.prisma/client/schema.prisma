generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EmployerRequest {
  id              String   @id @default(cuid())
  companyName     String?
  contactPerson   String?
  email           String?
  phone           String?
  location        String?
  website         String?
  specialty       String? // "engineering" | "accounting" | "administrative" | "other"
  requiredRole    String?
  requiredSkills  String[]
  teamSize        Int?
  experienceLevel String? // "graduate" | "mid" | "senior" | "lead" | "executive"
  employmentType  String[]
  projectType     String?
  description     String?
  timeline        String?
  budgetRange     String?
  files           File[]   @relation("EmployerFiles")
  submittedAt     DateTime @default(now())

  // New u&u fields
  engagementNeed   String?
  jobTitle         String?
  jobLocation      String?
  jobType          String?
  contactFirstName String?
  contactLastName  String?
  company          String?
  state            String?
  position         String?
  workEmail        String?
}

model CandidateSubmission {
  id               String   @id @default(cuid())
  firstName        String
  lastName         String
  email            String
  phone            String
  location         String?
  nationality      String?
  rightToWork      String?
  specialty        String?
  preferredRole    String?
  skills           String[]
  experienceLevel  String?
  yearsExperience  Int?
  employmentStatus String?
  linkedIn         String?
  portfolio        String?
  github           String?
  coverNote        String?
  files            File[]   @relation("CandidateFiles")
  submittedAt      DateTime @default(now())

  // New u&u fields
  coverLetterUrl               String?
  state                        String?
  careerExperience             String?
  careerGoals                  String[]
  reasonableAdjustments        String?
  reasonableAdjustmentsDetails String?
  preferredCommunication       String?
}

model EngineeringRequest {
  id          String   @id @default(cuid())
  fullName    String
  email       String
  phone       String
  company     String?
  serviceType String // "autocad" | "estimation" | "calculations" | "consultation"
  description String
  deadline    DateTime
  budget      String?
  files       File[]   @relation("EngineeringFiles")
  submittedAt DateTime @default(now())
}

model ContactMessage {
  id          String   @id @default(cuid())
  fullName    String
  email       String
  enquiryType String
  message     String
  submittedAt DateTime @default(now())
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model File {
  id                    String               @id @default(cuid())
  r2Key                 String               @unique
  publicUrl             String
  originalName          String
  mimeType              String
  sizeBytes             Int
  uploadedAt            DateTime             @default(now())
  employerRequest       EmployerRequest?     @relation("EmployerFiles", fields: [employerRequestId], references: [id])
  employerRequestId     String?
  candidateSubmission   CandidateSubmission? @relation("CandidateFiles", fields: [candidateSubmissionId], references: [id])
  candidateSubmissionId String?
  engineeringRequest    EngineeringRequest?  @relation("EngineeringFiles", fields: [engineeringRequestId], references: [id])
  engineeringRequestId  String?
}
